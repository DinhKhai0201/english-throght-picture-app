  "regions": [
    { "text": "What are things?", "x": 0.13, "y": 0.08, "w": 0.3, "h": 0.03 },
    { "text": "A house is a thing. Houses are things.", "x": 0.13, "y": 0.19, "w": 0.3, "h": 0.05 },
    { "text": "A hat is a thing. Hats are things.", "x": 0.13, "y": 0.28, "w": 0.3, "h": 0.05 },
    { "text": "Doors and windows are things.", "x": 0.12, "y": 0.38, "w": 0.35, "h": 0.05 },
    { "text": "Tables and seats are things.", "x": 0.12, "y": 0.43, "w": 0.35, "h": 0.05 },
    { "text": "This is a man.", "x": 0.63, "y": 0.1, "w": 0.2, "h": 0.03 },
    { "text": "This is a woman.", "x": 0.6, "y": 0.18, "w": 0.25, "h": 0.03 },
    { "text": "This is a boy.", "x": 0.64, "y": 0.25, "w": 0.2, "h": 0.03 },
    { "text": "This is a girl.", "x": 0.62, "y": 0.31, "w": 0.2, "h": 0.03 },
    { "text": "Men and women and boys and girls are not things. They are persons.", "x": 0.58, "y": 0.38, "w": 0.35, "h": 0.08 },
    { "text": "You are a person.", "x": 0.55, "y": 0.44, "w": 0.25, "h": 0.03 },
    { "text": "There are two persons in this room. They are a boy and a girl.", "x": 0.13, "y": 0.53, "w": 0.35, "h": 0.08 },
    { "text": "The girl is at the door.", "x": 0.13, "y": 0.82, "w": 0.35, "h": 0.03 },
    { "text": "The boy is at the window.", "x": 0.13, "y": 0.85, "w": 0.35, "h": 0.05 },
    { "text": "The girl will go to the window.", "x": 0.54, "y": 0.54, "w": 0.35, "h": 0.05 },
    { "text": "She will be with the boy at the window.", "x": 0.55, "y": 0.82, "w": 0.35, "h": 0.05 },
    { "text": "She will be with him at the window.", "x": 0.55, "y": 0.88, "w": 0.35, "h": 0.05 }
